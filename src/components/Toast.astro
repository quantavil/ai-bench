<!-- TOAST -->
<div x-show="toast.show" x-transition
  class="glass glass-hi fixed bottom-24 sm:bottom-5 left-1/2 -translate-x-1/2 z-[60] flex items-center gap-3 rounded-2xl px-4 py-3 mb-[env(safe-area-inset-bottom)]"
  role="status" aria-live="polite">
  <span class="shrink-0 w-2 h-2 rounded-full"
    :style="'background:var(--color-' + (toast.kind === 'ok' ? 'accent' : 'danger') + '); box-shadow:0 0 8px var(--color-' + (toast.kind === 'ok' ? 'accent' : 'danger') + ')'"></span>
  <span class="text-sm font-medium t-strong" x-text="toast.msg"></span>
  <template x-if="toast.undo">
    <button @click="runUndo()" class="btn btn-secondary px-2.5 py-1 text-sm" x-text="toast.undo.label"></button>
  </template>
</div>
