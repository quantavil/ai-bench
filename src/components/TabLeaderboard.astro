<!-- LEADERBOARD -->
<section x-show="!loading && data.models.length > 0 && tab === 'leaderboard'" class="mt-5">
  <template x-if="chartRows.length === 0">
    <div class="glass rounded-card p-8 text-center">
      <p class="text-sm t-soft">No runs logged in this category yet. Open the Prompts tab and log a few.</p>
    </div>
  </template>

  <div x-show="chartRows.length > 0">
    <div class="flex items-center justify-between gap-3">
      <div class="seg inline-flex rounded-btn p-1">
        <template x-for="m in CHART_MODES" :key="m.id">
          <button @click="chartMode = m.id" class="seg-btn px-3.5 py-1 text-xs font-semibold"
            :class="chartMode === m.id ? 'seg-btn-on' : 'hover:t-strong'" x-text="m.label"></button>
        </template>
      </div>
      <div class="flex items-center gap-2">
        <p class="font-mono text-[11px] t-soft hidden sm:block" x-show="chartMode === 'scatter'">Top-left is the
          sweet spot.</p>
        <div class="relative">
          <button @click="cycleSortMode()" 
            class="btn btn-ghost px-3 py-1.5 text-xs font-semibold flex items-center gap-1.5 cursor-pointer bg-[var(--chip-bg)] border border-[var(--glass-brd-soft)] hover:t-strong"
            :title="'Sort: ' + SORT_MODES.find(m => m.id === sortMode)?.label"
            aria-label="Cycle sort mode">
            <svg class="w-4 h-4 text-accent shrink-0"><use href="#icon-sort"></use></svg>
            <span x-text="SORT_MODES.find(m => m.id === sortMode)?.label"></span>
          </button>
        </div>
      </div>
    </div>

    <!-- Added overflow-hidden to keep corners clean, and overflow-x-auto for the chart wrapper -->
    <div class="glass rounded-card p-3 sm:p-5 mt-3 overflow-hidden">
      <div class="relative w-full overflow-x-auto scroll-slim pb-2" x-html="chartHtml"></div>
    </div>

    <!-- Ranked standings -->
    <div class="mt-6 space-y-2.5">
      <template x-for="row in leaderboardRows" :key="row.model.id">
        <div class="rounded-2xl px-3.5 py-3 flex items-center gap-3 leaderboard-row"
          :class="row.rank === 1 ? 'glass glass-hi' : (row.rank <= 3 ? 'glass glass-hi' : 'glass-soft')"
          :style="rowStyle(row)">
          <span class="w-8 shrink-0 text-center font-mono text-base font-bold tabular"
            :class="row.rank === 1 ? 'text-accent' : 't-soft'" x-text="row.rank"></span>
          <span class="shrink-0 w-3 h-3 rounded-full"
            :style="`background: ${providerColor(row.model.provider)}; box-shadow: 0 0 10px color-mix(in srgb, ${providerColor(row.model.provider)} 67%, transparent)`"></span>
          <div class="min-w-0 grow">
            <p class="font-semibold text-sm sm:text-base line-clamp-2 t-strong" x-text="row.model.name"></p>
            <p class="text-xs t-soft truncate">
              <span x-text="row.model.provider"></span>
              <span class="sm:hidden font-mono text-[11px]">
                <template x-if="row.avgTime !== null">
                  <span>· <span x-text="fmt1(row.avgTime) + 's'"></span></span>
                </template>
                · <span x-text="row.n"></span> runs
              </span>
              <template x-if="row.lowConfidence"><span
                  class="ml-1.5 rounded px-1.5 py-0.5 text-[10px] font-mono uppercase"
                  style="background:color-mix(in srgb,var(--color-danger) 18%,transparent);color:var(--color-danger)">low
                  n</span></template>
            </p>
          </div>
          <div class="shrink-0 text-right">
            <p class="font-mono text-xl font-bold leading-none tabular t-strong" x-text="fmt1(row.adjusted)"></p>
          </div>
          <div class="shrink-0 w-16 text-right hidden sm:block">
            <p class="font-mono text-sm tabular t-strong" x-text="row.avgTime !== null ? fmt1(row.avgTime) + 's' : '—'"></p>
            <p class="mt-1 font-mono text-[11px] t-soft tabular"><span x-text="row.n"></span> runs</p>
          </div>
        </div>
      </template>
    </div>
  </div>
</section>
